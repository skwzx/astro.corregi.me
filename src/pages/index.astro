---
// src/pages/index.astro
import Layout from "../components/Layout.astro";
import "../styles/global.css";
import "../styles/styles.css";
---

<!doctype html>
<html lang="es" class="h-full bg-primaryGreen">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.png?v=2" type="image/png" />
    <link rel="apple-touch-icon" href="/favicon.png?v=2" />

    <!-- PWA Settings -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
    <meta name="apple-mobile-web-app-title" content="corregi.me" />

    <!-- Primary Meta Tags -->
    <title>corregi.me | Corrector de Textos en Español Gratis con IA</title>
    <meta
      name="title"
      content="corregi.me | Corrector de Textos en Español Gratis con IA"
    />
    <meta
      name="description"
      content="🚀 Corrector y traductor de textos en español con IA. Corrige gramática, ortografía, estilo y traduce a cualquier idioma GRATIS. ¡Pruébalo ahora!"
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://corregi.me/" />
    <meta
      property="og:title"
      content="corregi.me | Corrector de Textos en Español Gratis con IA"
    />
    <meta
      property="og:description"
      content="🚀 Corrector y traductor de textos en español con IA. Corrige gramática, ortografía, estilo y traduce a cualquier idioma GRATIS."
    />
    <meta property="og:image" content="/social-card.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://corregi.me/" />
    <meta
      property="twitter:title"
      content="corregi.me | Corrector de Textos en Español Gratis con IA"
    />
    <meta
      property="twitter:description"
      content="🚀 Corrector y traductor de textos en español con IA. Corrige gramática, ortografía, estilo y traduce a cualquier idioma GRATIS."
    />
    <meta property="twitter:image" content="/social-card.png" />
    <meta
      property="twitter:image:alt"
      content="corregi.me - Corrector de textos en español con IA"
    />

    <!-- Geo Targeting -->
    <meta name="geo.region" content="UY-MO" />
    <meta name="geo.placename" content="Montevideo" />
    <meta name="geo.position" content="-34.9011;-56.1645" />
    <meta name="ICBM" content="-34.9011, -56.1645" />

    <!-- Additional Meta -->
    <meta
      name="keywords"
      content="corrector de textos, corrector español, traductor español, gramática española, corrector ortográfico, corrector gramatical, traductor online, IA español, inteligencia artificial texto, corregir textos gratis, traducir textos gratis, escritura española, redacción española, corrector online, herramienta escritura, corrector automático, traductor automático, revisar textos, mejorar escritura, Uruguay, Argentina, español rioplatense"
    />
    <meta name="author" content="corregi.me" />
    <meta
      name="robots"
      content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />
    <meta
      name="googlebot"
      content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />
    <meta name="language" content="Spanish" />
    <meta name="revisit-after" content="1 days" />
    <meta name="rating" content="general" />
    <meta name="distribution" content="global" />

    <!-- Accessibility -->
    <meta name="theme-color" content="#081711" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />

    <!-- Canonical URL -->
    <link rel="canonical" href="https://corregi.me/" />

    <!-- Schema.org structured data for SEO -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "corregi.me",
        "alternateName": "Corrector de Textos en Español",
        "description": "Corrector y traductor de textos en español con inteligencia artificial. Corrige gramática, ortografía, estilo y traduce a cualquier idioma de forma gratuita.",
        "url": "https://corregi.me",
        "applicationCategory": "UtilitiesApplication",
        "operatingSystem": "Web Browser",
        "browserRequirements": "Requires JavaScript",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD",
          "availability": "https://schema.org/InStock"
        },
        "creator": {
          "@type": "Organization",
          "name": "corregi.me",
          "url": "https://corregi.me"
        },
        "featureList": [
          "Corrección gramatical automática",
          "Corrección ortográfica",
          "Mejora de estilo",
          "Traducción a múltiples idiomas",
          "Inteligencia artificial",
          "Gratuito",
          "Procesamiento rápido"
        ],
        "inLanguage": "es"
      }
    </script>
  </head>
  <body class="bg-primaryGreen min-h-screen h-full text-white">
    <Layout />
    <script>
      import "../scripts/scripts.ts";

      // Handle back/forward cache restoration
      window.addEventListener("pageshow", (event) => {
        // If the page is loaded from the bfcache
        if (event.persisted) {
          // Reset form state if needed
          const form = document.getElementById(
            "correctionForm"
          ) as HTMLFormElement;
          const submitButton = document.getElementById("submitButton");
          const loadingSpinner = document.getElementById("loadingSpinner");

          if (form) form.reset();
          if (submitButton && loadingSpinner) {
            submitButton.classList.remove("hidden");
            loadingSpinner.classList.add("hidden");
            if (submitButton instanceof HTMLButtonElement) {
              submitButton.disabled = false;
            }
          }
        }
      });

      // Desregistrar cualquier Service Worker existente
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker
          .getRegistrations()
          .then(function (registrations) {
            for (let registration of registrations) {
              registration.unregister();
              console.log("Service Worker desregistrado");
            }
          });
      }
    </script>
  </body>
</html>
