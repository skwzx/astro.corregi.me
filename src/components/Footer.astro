---
import { Image } from "astro:assets";
import sparkLogo from "../assets/sparkLogo.png";
---

<!-- Footer Component -->
<div class="mt-8 text-center">
  <p class="text-xs text-gray-400">Powered by</p>
  <a
    href="https://sparkagencia.com.uy/"
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block"
  >
    <Image
      src={sparkLogo}
      alt="Powered by Spark"
      width={240}
      height={80}
      format="png"
      loading="eager"
      class="w-[100px] md:w-[120px] opacity-60 hover:scale-105 hover:opacity-100 transition-all duration-300"
    />
  </a>
</div>
