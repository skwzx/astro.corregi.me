---
import sparkLogo from "../assets/white svg.svg";
---

<!-- Footer Component -->
<div class="mt-8 mb-8 md:mb-0 text-center">
  <p class="text-xs text-gray-200">Desarollado por</p>
  <a
    href="https://spark.uy/"
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block"
    aria-label="Visit Spark Agency website"
  >
    <img
      src={"src" in sparkLogo ? sparkLogo.src : sparkLogo}
      alt="Desarollado por Spark"
      loading="eager"
      class="w-[80px] md:w-[90px] opacity-85 hover:scale-105 hover:opacity-100 transition-all duration-300"
    />
  </a>
</div>
